// Prisma schema for Labor Relations Central Intelligence
// - Per-user private KBs
// - System KBs (Central, All CBAs)
// - Document metadata for shared CBA uploads
// - Original file storage metadata
// - Extracted text storage for exact agreement search

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum KBVisibility {
  PRIVATE
  SHARED
  SYSTEM
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  name      String?
  createdAt DateTime @default(now())

  knowledgeBases KnowledgeBase[]
  documents      Document[]
}

model KnowledgeBase {
  id            String       @id @default(cuid())
  name          String
  vectorStoreId String
  visibility    KBVisibility @default(PRIVATE)

  // null = system KB (Central, All CBAs)
  ownerUserId   String?
  ownerUser     User?        @relation(fields: [ownerUserId], references: [id])

  createdAt     DateTime     @default(now())

  documents     Document[]

  @@index([ownerUserId])
  @@index([visibility])
  @@unique([ownerUserId, name])
}

model Document {
  id            String        @id @default(cuid())

  ownerUserId   String
  ownerUser     User          @relation(fields: [ownerUserId], references: [id])

  kbId          String
  kb            KnowledgeBase @relation(fields: [kbId], references: [id])

  openaiFileId  String
  filename      String
  createdAt     DateTime      @default(now())

  // CBA metadata (optional; captured when a user marks an upload as a CBA)
  isCba         Boolean       @default(false)

  // New metadata
  chapter       String?
  cbaType       String?

  // Existing metadata (state can hold comma-separated list for "State(s)" MVP)
  state         String?
  localUnion    String?
  employer      String?
  effectiveFrom DateTime?
  effectiveTo   DateTime?

  // Whether this document was also added to the system "All CBAs" KB
  sharedToCbas  Boolean       @default(false)

  // Original file storage metadata
  storageProvider String?
  storageKey      String?
  mimeType        String?
  fileSizeBytes   Int?
  sha256          String?

  textContent   DocumentText?

  @@index([kbId])
  @@index([ownerUserId])
  @@index([isCba])

  // Prevent duplicate filenames within a KB
  @@unique([kbId, filename])
}

model DocumentText {
  id              String    @id @default(cuid())
  documentId      String    @unique
  document        Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  extractedText   String
  extractionState String    @default("completed")
  extractedAt     DateTime  @default(now())

  @@index([documentId])
}